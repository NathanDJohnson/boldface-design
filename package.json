{
  "name": "boldface-design-theme",
  "version": "1.0.0",
  "description": "A custom WordPress theme built with ACF Pro blocks",
  "main": "index.js",
  "author": "Boldface Design",
  "license": "GPL-2.0-or-later",
  "scripts": {
    "start": "npm run watch",
    "watch": "npm run watch:css & npm run watch:js",
    "watch:css": "tailwindcss -i assets/css/input.css -o assets/css/style.css --watch",
    "watch:js": "webpack --mode development --watch",
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i assets/css/input.css -o assets/css/style.css --minify",
    "build:js": "webpack --mode production",
    "lint": "npm run lint:js",
    "lint:js": "eslint assets/js/**/*.js"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@tailwindcss/forms": "^0.5.0",
    "@tailwindcss/typography": "^0.5.0",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^9.1.0",
    "eslint": "^8.31.0",
    "eslint-config-wordpress": "^2.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.0"
  },
  "keywords": [
    "wordpress",
    "theme",
    "acf",
    "blocks"
  ]
}
